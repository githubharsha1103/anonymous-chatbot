# Local environment variables (not committed to git)
# Copy this file to .env.local and fill in your real credentials for local development

BOT_TOKEN=YOUR_REAL_BOT_TOKEN_HERE
ADMIN_IDS=YOUR_ADMIN_IDS_HERE
MONGODB_URI=YOUR_REAL_MONGODB_URI_HERE
DB_NAME=telugu_anomybot
GROUP_CHAT_ID=YOUR_GROUP_CHAT_ID_HERE
GROUP_INVITE_LINK=YOUR_GROUP_INVITE_LINK_HERE

# Optional overrides for local development
PORT=3000
WEBHOOK_PATH=/webhook
WEBAPP_URL=http://localhost:3000