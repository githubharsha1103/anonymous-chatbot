{
  "name": "anonymous-chatbot",
  "version": "1.0.0",
  "description": "An anonymous chatbot built using Telegraf",
  "keywords": [
    "anonymous",
    "telegram",
    "telegraf"
  ],
  "license": "MIT",
  "author": "sea-deep",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest --runInBand --config jest.config.js",
    "lint": "eslint . --ext .ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "build": "npm run clean && npx tsc",
    "init-db": "npx ts-node initDb.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "mongodb": "^7.1.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.3",
    "@types/node": "^22.19.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
