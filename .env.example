BOT_TOKEN=""
ADMIN_IDS=""
BOT_USERNAME=""

# MongoDB Configuration
MONGODB_URI="mongodb+srv://..."
DB_NAME="telugu_anomybot"

# Optional
PORT=3000
WEBHOOK_PATH=/webhook

# Web API Key (for securing admin endpoints)
WEB_API_KEY="your-secure-api-key-here"

# Group verification (get chat ID using /getgroupid command)
GROUP_CHAT_ID=""
GROUP_INVITE_LINK="https://t.me/yourgroup"

# Keep-alive interval in milliseconds (10 minutes = 600000)
KEEPALIVE_INTERVAL=600000

# Enable self-ping server for external cron jobs (true/false)
ENABLE_SELF_PING=true

# Self-ping server port (separate from main server)
SELF_PING_PORT=3001

# Telegram Stars premium pricing (optional overrides)
STARS_PREMIUM_DAILY=19
STARS_PREMIUM_WEEKLY=100
STARS_PREMIUM_MONTHLY=250
STARS_PREMIUM_YEARLY=1000
